<views:SingleRunMappingTool x:Class="Mapping_Tools.Views.ArCalculator.ArCalculatorView"
                            xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                            xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                            xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
                            xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
                            xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes"
                            xmlns:local="clr-namespace:Mapping_Tools.Views.ArCalculator"
                            xmlns:views="clr-namespace:Mapping_Tools.Views"
                            xmlns:vm="clr-namespace:Mapping_Tools.Viewmodels"
                            mc:Ignorable="d" 
                            d:DesignHeight="450" d:DesignWidth="800"
                            d:DataContext="{d:DesignInstance Type=vm:ArCalculatorVm}">
    <DockPanel LastChildFill="True">
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal">
            <TextBlock Text="AR Calculator" FontSize="32" FontWeight="Bold" Foreground="{DynamicResource PrimaryHueMidBrush}"/>
            <StackPanel Orientation="Horizontal" Margin="10" ToolTip="Click me!">
                <md:PopupBox>
                    <md:PopupBox.ToggleContent>
                        <md:PackIcon Kind="HelpCircle" Width="24" Height="24" Foreground="{DynamicResource SecondaryHueMidBrush}"/>
                    </md:PopupBox.ToggleContent>
                    <TextBlock TextWrapping="Wrap" MaxWidth="600" Padding="5">
                        Calculates the recommended AR based on the specified BPM.
                        <LineBreak/>
                        This tool does not provide an absolutely accurate AR, but it allows you to find an approximate value.
                    </TextBlock>
                </md:PopupBox>
            </StackPanel>
        </StackPanel>
        <StackPanel DockPanel.Dock="Bottom">
            <TextBlock TextWrapping="NoWrap" FontWeight="Bold" Opacity="0.58">
                Adapted by Redplcs. Original tool: <Hyperlink NavigateUri="http://maxime.delaby.free.fr/THEFIXER.html" RequestNavigate="OnOriginalToolNavigationRequested">THEFIXER.html</Hyperlink>
            </TextBlock>
        </StackPanel>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <StackPanel Grid.Row="0">
                <TextBox md:HintAssist.Hint="Beats per minute (BPM)"
                         ToolTip="The tempo, measured in beats per minute, which is used in beatmap."
                         Style="{StaticResource MaterialDesignFloatingHintTextBox}"
                         Text="{Binding Bpm}"/>
            </StackPanel>
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <md:Card Grid.Column="0" VerticalAlignment="Bottom" Margin="5" Padding="10">
                    <TextBox md:HintAssist.Hint="Recommended AR"
                             ToolTip="Outputs the AR that is recommended for use with the specified BPM."
                             Style="{StaticResource MaterialDesignFloatingHintTextBox}"
                             Text="{Binding CalculatedApproachRate}"
                             IsReadOnly="True"/>
                </md:Card>
                <Viewbox Grid.Column="1" Width="70" Margin="10">
                    <Button Content="{md:PackIcon Kind=Play, Size=36}"
                            ToolTip="Run this tool."
                            Style="{StaticResource MaterialDesignFloatingActionButton}"
                            Command="{Binding RunCommand}"/>
                </Viewbox>
            </Grid>
        </Grid>
    </DockPanel>
</views:SingleRunMappingTool>
